	<changeSet id="1733148100" author="jnsereko">
		<preConditions onFail="MARK_RAN">
			<not>
				<columnExists tableName="sale_order_lines" columnName="pricelist"/>
			</not>
		</preConditions>
		<addColumn tableName="sale_order_lines">
			<column name="pricelist" type="VARCHAR"/>
		</addColumn>
	</changeSet>

	<changeSet id="1733148101" author="jnsereko">
		<preConditions onFail="MARK_RAN">
			<not>
				<columnExists tableName="sale_order_lines" columnName="order_state"/>
			</not>
		</preConditions>
		<addColumn tableName="sale_order_lines">
			<column name="order_state" type="VARCHAR"/>
		</addColumn>
	</changeSet>
</databaseChangeLog>
