{
  "Name": "Orthanc inside Docker",
  "StorageDirectory": "/var/lib/orthanc/db",
  "StorageCompression": false,
  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,

  "PostgreSQL": {
    "EnableIndex": true,
    "EnableStorage": false,
    "Host": "postgres-orthanc",
    "Port": 5432,
    "Database": "orthanc",
    "Username": "orthanc",
    "Password": "orthanc",
    "Lock": false,
    "IndexConnectionsCount": 50,
    "TransactionMode": "ReadCommitted"
  },

  "Plugins": [
    "/usr/share/orthanc/plugins",
    "/usr/local/share/orthanc/plugins"
  ],
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "DicomAet": "ORTHANC",
  "DicomPort": 4242,
  "DicomAlwaysAllowStore": true,
  "DicomAlwaysAllowEcho": true,
  "StoneWebViewer": {},
  "OverwriteInstances": true,
  "SaveJobs": true,
  "ConcurrentJobs": 2,
  "Authorization": {
    "WebServiceRootUrl": "http://orthanc-auth-service:8000/",
    "WebServiceUsername": "orthanc",
    "WebServicePassword": "orthanc",
    "CheckedLevel": "studies",
    "TokenHttpHeaders": ["token"],
    "TokenGetArguments": ["token"],
    "StandardConfigurations": [
      "orthanc-explorer-2",
      "stone-webviewer"
    ],
    "UncheckedFolders": [
      "/auth/"
    ]
  },
  "DicomModalities": {
    "XmaruPro": ["XMARU", "192.168.1.XX", 104]
  },
  "OrthancExplorer2": {
    "IsDefaultOrthancUI": true,
    "Keycloak": {
      "Enable": true,
      "Url": "http://localhost:8084/",
      "Realm": "ozone",
      "ClientId": "orthanc"
    },
    "Options": {
      "EnableShares": true,
      "ShareType": "stone-viewer-publication",
      "InstantLinksValidity": 3600
    }
  }
}